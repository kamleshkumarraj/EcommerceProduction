{
  "version": 1,
  "deploy_type": "auto",
  "services": [
    {
      "name": "frontend",
      "path": "client",
      "type": "web",
      "health_check" : "/",
      "build": true,
      "dockerfile": "Dockerfile",
      "tag": "latest",
      "subdomain": "ecom-frontend",
      "ecr-repo": "client/ecom-frontend-repo",

      "port": 5173,
      "expose": true,
      

      "env": "ecom-frontend-env-key",
      "env_file": ".env",
      "env_inline": {
        "KEY": "value"
      },
      "restart" : "on-failure",
      "replicas" : 2,
      "deployment_strategy" : "rolling"

    },
    {
      "name": "backend",
      "path": "server",
      "type": "api",

      "subdomain": "ecom-backend",

      "build": true,
      "dockerfile": "Dockerfile",
      "tag": "latest",
      "ecr-repo": "server/ecom-backend-repo",

      "port": 3000,
      "expose": true,
      "health_check" : "/api/v2/health-check",

      "env": "ecom-backend-env-key",
      "env_file": ".env",
      "env_inline": {
        "KEY": "value"
      },
      "restart" : "on-failure",
      "replicas" : 2,
      "deployment_strategy" : "rolling"
    }
  ]
}