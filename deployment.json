{
  "version": 1,
  "deploy_type": "auto",
  "services": [
    {
      "name": "frontend",
      "path": "client",
      "type": "web",

      "build": true,
      "dockerfile": "Dockerfile",
      "tag": "latest",
      "subdomain": "ecom-frontend",
      "ecr-repo": "client/ecom-frontend-repo",

      "port": 5173,
      "expose": true,

      "env": "ecom-frontend-env-key",
      "env_file": ".env",
      "env_inline": {
        "KEY": "value"
      }

    },
    {
      "name": "backend",
      "path": "server",
      "type": "api",

      "subdomain": "ecom-backend",

      "build": true,
      "dockerfile": "Dockerfile",
      "tag": "latest",
      "ecr-repo": "server/ecom-backend-repo",

      "port": 3000,
      "expose": true,

      "env": "ecom-backend-env-key",
      "env_file": ".env",
      "env_inline": {
        "KEY": "value"
      }
    }
  ]
}